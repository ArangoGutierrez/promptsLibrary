{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "~/.cursor/hooks/inject-context.sh",
        "timeout": 10
      }
    ],
    "sessionEnd": [
      {
        "command": "~/.cursor/hooks/extract-learnings.sh",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "~/.cursor/hooks/format.sh",
        "timeout": 5
      }
    ],
    "beforeShellExecution": [
      {
        "command": "~/.cursor/hooks/sign-commits.sh"
      },
      {
        "command": "~/.cursor/hooks/security-gate.sh",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "~/.cursor/hooks/task-loop.sh",
        "loop_limit": 5
      }
    ]
  }
}
